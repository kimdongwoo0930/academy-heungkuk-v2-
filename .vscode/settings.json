{
  // ─── Java ───────────────────────────────────────────────
  "java.compile.nullAnalysis.mode": "disabled",
  "java.configuration.updateBuildConfiguration": "automatic",

  // JVM 힙 메모리 (Language Server에 할당, MB 단위)
  "java.jdt.ls.vmargs": "-XX:+UseG1GC -Xms512m -Xmx2048m -XX:+UseStringDeduplication",

  // 자동완성 관련
  "java.completion.enabled": true,
  "java.completion.guessMethodArguments": "auto",
  "java.completion.importOrder": ["java", "javax", "jakarta", "org", "com", ""],
  "java.completion.filteredTypes": [
    "java.awt.*",
    "com.sun.*",
    "sun.*"
  ],

  // import 자동 정리
  "editor.codeActionsOnSave": {
    "source.organizeImports": "explicit"
  },

  // 인레이 힌트 (파라미터명, 타입 표시)
  "java.inlayHints.parameterNames.enabled": "literals",

  //─── Spring Boot ────────────────────────────────────────
  "spring-boot.ls.java.heap": "1024m",
  "spring-boot.ls.problem.application-properties.PROP_UNKNOWN_PROPERTY": "WARNING",

  // ─── 편집기 공통 ─────────────────────────────────────────
  "editor.tabSize": 4,
  "editor.insertSpaces": true,
  "editor.formatOnSave": true,
  "editor.suggestSelection": "first",
  "editor.snippetSuggestions": "top",
  "editor.linkedEditing": true,

  // ─── 파일 ────────────────────────────────────────────────
  "files.exclude": {
    "**/.gradle": true,
    "**/bin": true,
    "**/build": true,
    "**/.classpath": true,
    "**/.project": true,
    "**/.settings": true,
    "**/.factorypath": true
  },
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true
}
