{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    },
    {
      "name": "DS_LOKI",
      "label": "Loki",
      "type": "datasource",
      "pluginId": "loki",
      "pluginName": "Loki"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "9.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    { "type": "datasource", "id": "loki", "name": "Loki", "version": "1.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    { "type": "panel", "id": "logs", "name": "Logs", "version": "" }
  ],
  "title": "HKA 통합 모니터링",
  "uid": "hka-overview-v1",
  "description": "흥국생명 연수원 — Spring Boot · 서버 · Docker · NGINX 통합 현황",
  "tags": ["hka", "spring", "docker", "nginx"],
  "timezone": "Asia/Seoul",
  "schemaVersion": 38,
  "version": 2,
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "annotations": { "list": [] },
  "templating": { "list": [] },

  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Spring Boot",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }
    },

    {
      "id": 2,
      "type": "stat",
      "title": "Uptime",
      "description": "애플리케이션 가동 시간",
      "gridPos": { "x": 0, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 300 },
              { "color": "green", "value": 3600 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "process_uptime_seconds{job=\"spring-backend\"}",
          "legendFormat": "Uptime",
          "refId": "A"
        }
      ]
    },

    {
      "id": 3,
      "type": "stat",
      "title": "Heap Used",
      "description": "JVM Heap 메모리 사용량",
      "gridPos": { "x": 6, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 268435456 },
              { "color": "red", "value": 536870912 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area"
      },
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes{job=\"spring-backend\", area=\"heap\"})",
          "legendFormat": "Heap Used",
          "refId": "A"
        }
      ]
    },

    {
      "id": 4,
      "type": "gauge",
      "title": "Spring CPU Usage",
      "description": "Spring 프로세스 CPU 사용률",
      "gridPos": { "x": 12, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 0.8 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "process_cpu_usage{job=\"spring-backend\"}",
          "legendFormat": "CPU",
          "refId": "A"
        }
      ]
    },

    {
      "id": 5,
      "type": "stat",
      "title": "HTTP 요청 (req/s)",
      "description": "분당 HTTP 요청 수",
      "gridPos": { "x": 18, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area"
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"spring-backend\"}[1m]))",
          "legendFormat": "req/s",
          "refId": "A"
        }
      ]
    },

    {
      "id": 10,
      "type": "timeseries",
      "title": "JVM Heap 사용량 추이",
      "description": "Used / Committed / Max",
      "gridPos": { "x": 0, "y": 5, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes{job=\"spring-backend\", area=\"heap\"})",
          "legendFormat": "Used",
          "refId": "A"
        },
        {
          "expr": "sum(jvm_memory_committed_bytes{job=\"spring-backend\", area=\"heap\"})",
          "legendFormat": "Committed",
          "refId": "B"
        },
        {
          "expr": "sum(jvm_memory_max_bytes{job=\"spring-backend\", area=\"heap\"})",
          "legendFormat": "Max",
          "refId": "C"
        }
      ]
    },

    {
      "id": 11,
      "type": "timeseries",
      "title": "HTTP 상태 코드별 요청",
      "description": "1m 기준 상태 코드별 req/s",
      "gridPos": { "x": 12, "y": 5, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "sum by(status) (rate(http_server_requests_seconds_count{job=\"spring-backend\"}[1m]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 20,
      "type": "row",
      "title": "서버 리소스 (node-exporter)",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 13, "w": 24, "h": 1 }
    },

    {
      "id": 21,
      "type": "timeseries",
      "title": "서버 CPU 사용률",
      "description": "호스트 전체 CPU 사용률 (%)",
      "gridPos": { "x": 0, "y": 14, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "showPoints": "never"
          },
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 85 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "100 - (avg by(instance) (irate(node_cpu_seconds_total{job=\"node-exporter\", mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "CPU 사용률",
          "refId": "A"
        }
      ]
    },

    {
      "id": 22,
      "type": "timeseries",
      "title": "서버 메모리 사용량",
      "description": "Used / Available / Total",
      "gridPos": { "x": 12, "y": 14, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "showPoints": "never"
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "node_memory_MemTotal_bytes{job=\"node-exporter\"} - node_memory_MemAvailable_bytes{job=\"node-exporter\"}",
          "legendFormat": "Used",
          "refId": "A"
        },
        {
          "expr": "node_memory_MemAvailable_bytes{job=\"node-exporter\"}",
          "legendFormat": "Available",
          "refId": "B"
        },
        {
          "expr": "node_memory_MemTotal_bytes{job=\"node-exporter\"}",
          "legendFormat": "Total",
          "refId": "C"
        }
      ]
    },

    {
      "id": 23,
      "type": "gauge",
      "title": "디스크 사용률",
      "description": "루트(/) 파티션 디스크 사용률",
      "gridPos": { "x": 0, "y": 22, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "100 - (node_filesystem_avail_bytes{job=\"node-exporter\", mountpoint=\"/\", fstype!=\"tmpfs\"} / node_filesystem_size_bytes{job=\"node-exporter\", mountpoint=\"/\", fstype!=\"tmpfs\"} * 100)",
          "legendFormat": "Disk Used %",
          "refId": "A"
        }
      ]
    },

    {
      "id": 24,
      "type": "stat",
      "title": "네트워크 수신",
      "gridPos": { "x": 6, "y": 22, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area"
      },
      "targets": [
        {
          "expr": "sum(irate(node_network_receive_bytes_total{job=\"node-exporter\", device!~\"lo\"}[1m]))",
          "legendFormat": "수신",
          "refId": "A"
        }
      ]
    },

    {
      "id": 25,
      "type": "stat",
      "title": "네트워크 송신",
      "gridPos": { "x": 12, "y": 22, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area"
      },
      "targets": [
        {
          "expr": "sum(irate(node_network_transmit_bytes_total{job=\"node-exporter\", device!~\"lo\"}[1m]))",
          "legendFormat": "송신",
          "refId": "A"
        }
      ]
    },

    {
      "id": 30,
      "type": "row",
      "title": "Docker 컨테이너 (cAdvisor)",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 26, "w": 24, "h": 1 }
    },

    {
      "id": 31,
      "type": "timeseries",
      "title": "컨테이너별 CPU 사용률",
      "description": "2m 기준 컨테이너별 CPU (%)",
      "gridPos": { "x": 0, "y": 27, "w": 12, "h": 9 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "custom": { "lineWidth": 1, "fillOpacity": 5, "showPoints": "never" },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max"]
        }
      },
      "targets": [
        {
          "expr": "sum by(name) (rate(container_cpu_usage_seconds_total{job=\"cadvisor\", name!=\"\", name!~\".*_.*_.*\"}[2m])) * 100",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 32,
      "type": "timeseries",
      "title": "컨테이너별 메모리 사용량",
      "description": "컨테이너별 메모리 RSS (bytes)",
      "gridPos": { "x": 12, "y": 27, "w": 12, "h": 9 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "min": 0,
          "custom": { "lineWidth": 1, "fillOpacity": 5, "showPoints": "never" },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max"]
        }
      },
      "targets": [
        {
          "expr": "container_memory_rss{job=\"cadvisor\", name!=\"\", name!~\".*_.*_.*\"}",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 40,
      "type": "row",
      "title": "로그 (Loki)",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 36, "w": 24, "h": 1 }
    },

    {
      "id": 41,
      "type": "timeseries",
      "title": "ERROR 로그 발생률",
      "description": "5분 윈도우 기준 Spring 에러 로그 건수",
      "gridPos": { "x": 0, "y": 37, "w": 12, "h": 6 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "red" },
          "custom": { "lineWidth": 2, "fillOpacity": 20, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"hka-backend\", log_type=\"error\"}[5m]))",
          "legendFormat": "ERROR 건수",
          "refId": "A"
        }
      ]
    },

    {
      "id": 42,
      "type": "timeseries",
      "title": "NGINX 5xx 발생률",
      "description": "5분 윈도우 기준 NGINX 5xx 응답 건수",
      "gridPos": { "x": 12, "y": 37, "w": 12, "h": 6 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "orange" },
          "custom": { "lineWidth": 2, "fillOpacity": 20, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"hka-nginx\", log_type=\"nginx-access\", status=~\"5..\"}[5m]))",
          "legendFormat": "5xx 건수",
          "refId": "A"
        }
      ]
    },

    {
      "id": 43,
      "type": "logs",
      "title": "Spring 실시간 로그 (전체)",
      "description": "Spring 전체 로그 — app.log",
      "gridPos": { "x": 0, "y": 43, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "sortOrder": "Ascending"
      },
      "targets": [
        {
          "expr": "{job=\"hka-backend\"}",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },

    {
      "id": 44,
      "type": "logs",
      "title": "Spring 에러 로그",
      "description": "ERROR 레벨 로그만 — error.log",
      "gridPos": { "x": 12, "y": 43, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "sortOrder": "Ascending"
      },
      "targets": [
        {
          "expr": "{job=\"hka-backend\", log_type=\"error\"}",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },

    {
      "id": 45,
      "type": "logs",
      "title": "NGINX Access 로그",
      "description": "NGINX 접근 로그 (JSON 파싱) — method·status 라벨 필터 가능",
      "gridPos": { "x": 0, "y": 51, "w": 24, "h": 8 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": false,
        "sortOrder": "Ascending"
      },
      "targets": [
        {
          "expr": "{job=\"hka-nginx\", log_type=\"nginx-access\"}",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },

    {
      "id": 46,
      "type": "logs",
      "title": "인증 로그",
      "description": "로그인 · 토큰 발급 · 인증 실패 — auth.log",
      "gridPos": { "x": 0, "y": 59, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "sortOrder": "Ascending"
      },
      "targets": [
        {
          "expr": "{job=\"hka-backend\", log_type=\"auth\"}",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },

    {
      "id": 47,
      "type": "logs",
      "title": "예약 로그",
      "description": "예약 생성 · 수정 · 삭제 — reservation.log",
      "gridPos": { "x": 12, "y": 59, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
